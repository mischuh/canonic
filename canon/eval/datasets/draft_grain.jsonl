# Labeled draft/grain-inference cases for the E10 baseline harness (SPEC-E10 §7, GH-66).
# One JSON object per line: {relation, columns:[{name,type,nullable}], expected_grain:[...]}.
# Mix of single-column surrogate keys, natural keys, and composite/junction grains.
{"relation": "app.customers", "columns": [{"name": "id", "type": "int", "nullable": false}, {"name": "name", "type": "string", "nullable": false}, {"name": "email", "type": "string", "nullable": true}, {"name": "created_at", "type": "timestamp", "nullable": false}], "expected_grain": ["id"]}
{"relation": "app.orders", "columns": [{"name": "id", "type": "int", "nullable": false}, {"name": "customer_id", "type": "int", "nullable": false}, {"name": "status", "type": "string", "nullable": false}, {"name": "total", "type": "decimal", "nullable": false}, {"name": "placed_at", "type": "timestamp", "nullable": false}], "expected_grain": ["id"]}
{"relation": "app.order_items", "columns": [{"name": "order_id", "type": "int", "nullable": false}, {"name": "product_id", "type": "int", "nullable": false}, {"name": "quantity", "type": "int", "nullable": false}, {"name": "unit_price", "type": "decimal", "nullable": false}], "expected_grain": ["order_id", "product_id"]}
{"relation": "app.products", "columns": [{"name": "sku", "type": "string", "nullable": false}, {"name": "name", "type": "string", "nullable": false}, {"name": "price", "type": "decimal", "nullable": false}, {"name": "active", "type": "bool", "nullable": false}], "expected_grain": ["sku"]}
{"relation": "app.user_roles", "columns": [{"name": "user_id", "type": "int", "nullable": false}, {"name": "role_id", "type": "int", "nullable": false}, {"name": "granted_at", "type": "timestamp", "nullable": false}], "expected_grain": ["user_id", "role_id"]}
{"relation": "app.events", "columns": [{"name": "event_id", "type": "string", "nullable": false}, {"name": "user_id", "type": "int", "nullable": true}, {"name": "kind", "type": "string", "nullable": false}, {"name": "occurred_at", "type": "timestamp", "nullable": false}, {"name": "payload", "type": "json", "nullable": true}], "expected_grain": ["event_id"]}
{"relation": "app.daily_sales", "columns": [{"name": "day", "type": "date", "nullable": false}, {"name": "region", "type": "string", "nullable": false}, {"name": "revenue", "type": "decimal", "nullable": false}, {"name": "orders", "type": "int", "nullable": false}], "expected_grain": ["day", "region"]}
{"relation": "app.addresses", "columns": [{"name": "id", "type": "int", "nullable": false}, {"name": "customer_id", "type": "int", "nullable": false}, {"name": "line1", "type": "string", "nullable": false}, {"name": "city", "type": "string", "nullable": false}, {"name": "postal_code", "type": "string", "nullable": true}], "expected_grain": ["id"]}
{"relation": "app.memberships", "columns": [{"name": "org_id", "type": "int", "nullable": false}, {"name": "user_id", "type": "int", "nullable": false}, {"name": "joined_at", "type": "timestamp", "nullable": false}, {"name": "active", "type": "bool", "nullable": false}], "expected_grain": ["org_id", "user_id"]}
{"relation": "app.invoices", "columns": [{"name": "invoice_no", "type": "string", "nullable": false}, {"name": "account_id", "type": "int", "nullable": false}, {"name": "amount", "type": "decimal", "nullable": false}, {"name": "issued_on", "type": "date", "nullable": false}], "expected_grain": ["invoice_no"]}
