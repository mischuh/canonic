{
  "$defs": {
    "Compiled": {
      "description": "The compiled SQL and its dialect (SPEC \u00a72.2 ``compiled``).",
      "properties": {
        "sql": {
          "title": "Sql",
          "type": "string"
        },
        "dialect": {
          "title": "Dialect",
          "type": "string"
        }
      },
      "required": [
        "sql",
        "dialect"
      ],
      "title": "Compiled",
      "type": "object"
    },
    "FinalityOut": {
      "description": "Finality metadata block in a query response (SPEC-E5-E15 stage 8).",
      "properties": {
        "watermark": {
          "title": "Watermark",
          "type": "string"
        },
        "sources_used": {
          "items": {
            "type": "string"
          },
          "title": "Sources Used",
          "type": "array"
        },
        "final_rows": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Final Rows"
        },
        "provisional_rows": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provisional Rows"
        }
      },
      "required": [
        "watermark",
        "sources_used"
      ],
      "title": "FinalityOut",
      "type": "object"
    },
    "FiredGuardrailOut": {
      "description": "A guardrail that fired during compilation (mirrors compiler ``FiredGuardrail``).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "FiredGuardrailOut",
      "type": "object"
    },
    "QueryMetadata": {
      "description": "The E5 compiler metadata block carried alongside a result (SPEC \u00a72.2).",
      "properties": {
        "resolved": {
          "additionalProperties": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Resolved",
          "type": "object"
        },
        "guardrails_fired": {
          "items": {
            "$ref": "#/$defs/FiredGuardrailOut"
          },
          "title": "Guardrails Fired",
          "type": "array"
        },
        "freshness": {
          "items": {
            "$ref": "#/$defs/SourceFreshnessOut"
          },
          "title": "Freshness",
          "type": "array"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "contract_schema": {
          "default": "2.0",
          "title": "Contract Schema",
          "type": "string"
        },
        "finality": {
          "anyOf": [
            {
              "$ref": "#/$defs/FinalityOut"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "related": {
          "$ref": "#/$defs/RelatedOut",
          "default": {
            "unused_dimensions": [],
            "sibling_metrics": []
          }
        }
      },
      "required": [
        "resolved",
        "guardrails_fired",
        "freshness"
      ],
      "title": "QueryMetadata",
      "type": "object"
    },
    "RelatedDimensionOut": {
      "description": "An unused queryable dimension surfaced in ``metadata.related`` (SPEC-E7/E8 \u00a72.2).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        }
      },
      "required": [
        "name",
        "source"
      ],
      "title": "RelatedDimensionOut",
      "type": "object"
    },
    "RelatedMetricOut": {
      "description": "An active sibling metric surfaced in ``metadata.related`` (SPEC-E7/E8 \u00a72.2).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "name",
        "source"
      ],
      "title": "RelatedMetricOut",
      "type": "object"
    },
    "RelatedOut": {
      "description": "The ``metadata.related`` block: unused dimensions and sibling metrics (SPEC-E7/E8 \u00a72.2).",
      "properties": {
        "unused_dimensions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RelatedDimensionOut"
          },
          "title": "Unused Dimensions",
          "type": "array"
        },
        "sibling_metrics": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RelatedMetricOut"
          },
          "title": "Sibling Metrics",
          "type": "array"
        }
      },
      "title": "RelatedOut",
      "type": "object"
    },
    "SourceFreshnessOut": {
      "description": "Per-source freshness metadata (mirrors compiler ``SourceFreshness``).",
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "last_validated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Validated At"
        },
        "stale": {
          "default": false,
          "title": "Stale",
          "type": "boolean"
        }
      },
      "required": [
        "source"
      ],
      "title": "SourceFreshnessOut",
      "type": "object"
    }
  },
  "description": "The ``compile`` response: ``compiled`` + ``metadata`` without a result set (SPEC \u00a72.2).",
  "properties": {
    "compiled": {
      "$ref": "#/$defs/Compiled"
    },
    "metadata": {
      "$ref": "#/$defs/QueryMetadata"
    }
  },
  "required": [
    "compiled",
    "metadata"
  ],
  "title": "CompileOutput",
  "type": "object"
}
