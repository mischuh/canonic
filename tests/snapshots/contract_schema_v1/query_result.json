{
  "$defs": {
    "Compiled": {
      "description": "The compiled SQL and its dialect (SPEC \u00a72.2 ``compiled``).",
      "properties": {
        "sql": {
          "title": "Sql",
          "type": "string"
        },
        "dialect": {
          "title": "Dialect",
          "type": "string"
        }
      },
      "required": [
        "sql",
        "dialect"
      ],
      "title": "Compiled",
      "type": "object"
    },
    "FinalityOut": {
      "description": "Finality metadata block in a query response (SPEC-E5-E15 stage 8).",
      "properties": {
        "watermark": {
          "title": "Watermark",
          "type": "string"
        },
        "sources_used": {
          "items": {
            "type": "string"
          },
          "title": "Sources Used",
          "type": "array"
        },
        "final_rows": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Final Rows"
        },
        "provisional_rows": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provisional Rows"
        }
      },
      "required": [
        "watermark",
        "sources_used"
      ],
      "title": "FinalityOut",
      "type": "object"
    },
    "FiredGuardrailOut": {
      "description": "A guardrail that fired during compilation (mirrors compiler ``FiredGuardrail``).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "title": "FiredGuardrailOut",
      "type": "object"
    },
    "QueryMetadata": {
      "description": "The E5 compiler metadata block carried alongside a result (SPEC \u00a72.2).",
      "properties": {
        "resolved": {
          "additionalProperties": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "title": "Resolved",
          "type": "object"
        },
        "guardrails_fired": {
          "items": {
            "$ref": "#/$defs/FiredGuardrailOut"
          },
          "title": "Guardrails Fired",
          "type": "array"
        },
        "freshness": {
          "items": {
            "$ref": "#/$defs/SourceFreshnessOut"
          },
          "title": "Freshness",
          "type": "array"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "contract_schema": {
          "default": "1.3",
          "title": "Contract Schema",
          "type": "string"
        },
        "finality": {
          "anyOf": [
            {
              "$ref": "#/$defs/FinalityOut"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "resolved",
        "guardrails_fired",
        "freshness"
      ],
      "title": "QueryMetadata",
      "type": "object"
    },
    "ResultColumn": {
      "description": "A single column descriptor in a ResultSet.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "ResultColumn",
      "type": "object"
    },
    "ResultSet": {
      "description": "Normalized query result emitted by run_read_only_sql().",
      "properties": {
        "columns": {
          "items": {
            "$ref": "#/$defs/ResultColumn"
          },
          "title": "Columns",
          "type": "array"
        },
        "rows": {
          "items": {
            "items": {},
            "type": "array"
          },
          "title": "Rows",
          "type": "array"
        },
        "truncated": {
          "default": false,
          "title": "Truncated",
          "type": "boolean"
        },
        "bytes_scanned": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bytes Scanned"
        }
      },
      "required": [
        "columns",
        "rows"
      ],
      "title": "ResultSet",
      "type": "object"
    },
    "SourceFreshnessOut": {
      "description": "Per-source freshness metadata (mirrors compiler ``SourceFreshness``).",
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "last_validated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Validated At"
        },
        "stale": {
          "default": false,
          "title": "Stale",
          "type": "boolean"
        }
      },
      "required": [
        "source"
      ],
      "title": "SourceFreshnessOut",
      "type": "object"
    }
  },
  "description": "The combined ``query`` response: ``result`` + ``compiled`` + ``metadata`` (SPEC \u00a72.2).",
  "properties": {
    "result": {
      "$ref": "#/$defs/ResultSet"
    },
    "compiled": {
      "$ref": "#/$defs/Compiled"
    },
    "metadata": {
      "$ref": "#/$defs/QueryMetadata"
    }
  },
  "required": [
    "result",
    "compiled",
    "metadata"
  ],
  "title": "QueryResult",
  "type": "object"
}
